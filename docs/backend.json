
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Firm": {
      "title": "Firm",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gstin": { "type": "string" },
        "logo": { "type": "string" },
        "units": { "type": "array" }
      }
    },
    "Plant": {
      "title": "Plant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firmId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      }
    },
    "Employee": {
      "title": "Employee",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "employeeId": { "type": "string" },
        "firmId": { "type": "string" },
        "unitId": { "type": "string" }
      }
    },
    "Attendance": {
      "title": "Attendance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "LeaveRequest": {
      "title": "LeaveRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "department": { "type": "string" },
        "designation": { "type": "string" },
        "fromDate": { "type": "string" },
        "toDate": { "type": "string" },
        "days": { "type": "number" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["UNDER_PROCESS", "APPROVED", "REJECTED"] },
        "rejectReason": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "description": "Admin users" } },
      { "path": "/firms/{firmId}", "definition": { "entityName": "Firm", "description": "Legal entities" } },
      { "path": "/plants/{plantId}", "definition": { "entityName": "Plant", "description": "Geofence locations" } },
      { "path": "/employees/{employeeId}", "definition": { "entityName": "Employee", "description": "Workforce profiles" } },
      { "path": "/attendance/{attendanceId}", "definition": { "entityName": "Attendance", "description": "Daily logs" } },
      { "path": "/payroll/{payrollId}", "definition": { "entityName": "Payroll", "description": "Monthly earnings" } },
      { "path": "/vouchers/{voucherId}", "definition": { "entityName": "Voucher", "description": "Cash advances" } },
      { "path": "/holidays/{holidayId}", "definition": { "entityName": "Holiday", "description": "Organization calendar" } },
      { "path": "/notifications/{notifId}", "definition": { "entityName": "Notification", "description": "Activity alerts" } },
      { "path": "/leaveRequests/{leaveId}", "definition": { "entityName": "LeaveRequest", "description": "Employee leave applications" } }
    ]
  }
}
