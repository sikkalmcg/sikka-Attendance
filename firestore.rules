rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SIKKATRACK HRMS SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a multi-tenant, role-based access control (RBAC) model 
     * for Sikka Industries & Logistics. Security is enforced through a combination 
     * of hierarchical path validation and denormalized identity fields.
     *
     * Data Structure:
     * - /users: Global user profiles containing roles and firm associations.
     * - /firms: Root collection for all company-specific data.
     * - /firms/{firmId}/employees/{employeeId}/...: Scoped data for specific employees.
     *
     * Key Security Decisions:
     * 1. Super Admin: A global 'isSuperAdmin' flag in the User document grants absolute access.
     * 2. Firm Segregation: Admin and HR roles are strictly scoped to their assigned 'firmId'.
     * 3. Employee Self-Service: Employees can access their own records (attendance, payroll, vouchers)
     *    based on the 'employeeId' matching their authenticated UID.
     * 4. Relational Integrity: On creation, documents must include a 'firmId' or 'employeeId' 
     *    that matches the path wildcards to ensure query consistency.
     * 5. Immutability: Critical relationship fields (firmId, employeeId) are immutable once set.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getAuthUser().isSuperAdmin == true;
    }

    function hasRole(role) {
      return isSignedIn() && getAuthUser().role == role;
    }

    function belongsToFirm(firmId) {
      return isSignedIn() && getAuthUser().firmId == firmId;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Renamed and modified to accept 'resource' as an argument, addressing the 'resource' variable name warning
    // This function checks if the current user is the owner of an *existing* document.
    function isOwnerOfExistingDoc(userId, currentResource) {
      return currentResource != null && isUser(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection. Owners can manage their profile, while Super Admins manage roles.
     * @path /users/{userId}
     * @allow User (userId_123) to (get) their own profile.
     * @deny User (userId_456) from (update) the role of (userId_123).
     * @principle Ownership for personal data; Administrative control for roles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && (isUser(userId) || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isUser(userId);
      // Using isOwnerOfExistingDoc to explicitly check for document existence and ownership for updates
      allow update: if isSuperAdmin() || (isOwnerOfExistingDoc(userId, resource) && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Root firm details. Access restricted to Firm Admins and Super Admins.
     * @path /firms/{firmId}
     * @allow Admin of FirmA to (get) FirmA details.
     * @deny Admin of FirmA from (list) all firms in the system.
     * @principle Structural segregation by firmId.
     */
    match /firms/{firmId} {
      allow get: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      /**
       * @description Plant locations for GPS validation. Managed by Firm Admins.
       * @path /firms/{firmId}/plants/{plantId}
       * @allow Employee to (list) plants in their firm for attendance marking.
       * @deny Employee from (create) a new plant location.
       */
      match /plants/{plantId} {
        allow get, list: if isSuperAdmin() || belongsToFirm(firmId);
        allow create: if isSuperAdmin() || (belongsToFirm(firmId) && hasRole('ADMIN'));
        allow update: if isSuperAdmin() || (resource != null && belongsToFirm(firmId) && hasRole('ADMIN'));
        allow delete: if isSuperAdmin() || (resource != null && belongsToFirm(firmId) && hasRole('ADMIN'));
      }

      /**
       * @description Holiday calendar for the firm.
       * @path /firms/{firmId}/holidays/{holidayId}
       */
      match /holidays/{holidayId} {
        allow get, list: if isSuperAdmin() || belongsToFirm(firmId);
        allow create, update, delete: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
      }

      /**
       * @description Detailed employee profiles within a firm.
       * @path /firms/{firmId}/employees/{employeeId}
       * @allow Employee to (get) their own employee profile.
       * @deny HR of FirmA from (update) employee details in FirmB.
       */
      match /employees/{employeeId} {
        allow get: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
        allow list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR'));
        allow create: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')) && request.resource.data.firmId == firmId);
        allow update: if isSuperAdmin() || (resource != null && belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')) && request.resource.data.firmId == resource.data.firmId);
        allow delete: if isSuperAdmin();

        /**
         * @description Salary history logs. Highly sensitive, Admin/HR only.
         * @path /firms/{firmId}/employees/{employeeId}/salaryHistory/{id}
         */
        match /salaryHistory/{id} {
          allow get: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR'));
          allow list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR'));
          allow create, update, delete: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
        }

        /**
         * @description Daily attendance records. Employees create (check-in/out), Admins approve.
         * @path /firms/{firmId}/employees/{employeeId}/attendance/{id}
         * @allow Employee to (create) their own attendance record.
         * @deny Employee from (update) their attendance status to 'PRESENT' manually.
         */
        match /attendance/{id} {
          allow get, list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
          allow create: if isSuperAdmin() || (belongsToFirm(firmId) && isUser(employeeId) && request.resource.data.employeeId == employeeId);
          // Using isOwnerOfExistingDoc for employee self-update conditions on attendance
          allow update: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || (isOwnerOfExistingDoc(employeeId, resource) && request.resource.data.status == resource.data.status)));
          allow delete: if isSuperAdmin();
        }

        /**
         * @description Monthly payroll records.
         * @path /firms/{firmId}/employees/{employeeId}/payrolls/{id}
         */
        match /payrolls/{id} {
          allow get, list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
          allow create, update, delete: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));

          match /payments/{paymentId} {
            allow get, list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
            allow create, update, delete: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
          }
        }

        /**
         * @description Advance payment vouchers.
         * @path /firms/{firmId}/employees/{employeeId}/vouchers/{id}
         */
        match /vouchers/{id} {
          allow get, list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
          allow create: if isSuperAdmin() || (belongsToFirm(firmId) && isUser(employeeId) && request.resource.data.employeeId == employeeId);
          allow update: if isSuperAdmin() || (resource != null && belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
          allow delete: if isSuperAdmin();

          match /payments/{paymentId} {
            allow get, list: if isSuperAdmin() || belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR') || isUser(employeeId));
            allow create, update, delete: if isSuperAdmin() || (belongsToFirm(firmId) && (hasRole('ADMIN') || hasRole('HR')));
          }
        }
      }
    }
  }
}